//@version=5
strategy("Volume Profile Strategy", shorttitle="VP", overlay=true, pyramiding=0, default_qty_type=strategy.percent_of_equity, default_qty_value=100, initial_capital=1000, commission_type=strategy.commission.percent, commission_value=0.1)

lookback_vol = input.int(20, title="Volume Lookback", minval=5, maxval=50)
volume_threshold = input.float(1.5, title="Volume Multiplier", minval=1.0, maxval=3.0)
tp_pips = input.float(120, title="Take Profit (pips)", minval=20, maxval=300)
sl_pips = input.float(70, title="Stop Loss (pips)", minval=20, maxval=150)

avg_vol = ta.sma(volume, lookback_vol)
vol_surge = volume > avg_vol * volume_threshold
price_at_support = close > open
price_at_resistance = close < open
strong_uptrend = close > ta.sma(close, 50)
strong_downtrend = close < ta.sma(close, 50)

entry_long = vol_surge and price_at_support and strong_uptrend
entry_short = vol_surge and price_at_resistance and strong_downtrend

var bool in_pos = false
var string pos_type = ""
var float pos_ent = 0.0

if entry_long and not in_pos
    in_pos := true
    pos_type := "LONG"
    pos_ent := close
    strategy.entry("VP Long", strategy.long)

if entry_short and not in_pos
    in_pos := true
    pos_type := "SHORT"
    pos_ent := close
    strategy.entry("VP Short", strategy.short)

if in_pos
    if pos_type == "LONG"
        if high >= pos_ent + (tp_pips / 10000) or low <= pos_ent - (sl_pips / 10000)
            in_pos := false
            strategy.close("VP Long")
    else
        if low <= pos_ent - (tp_pips / 10000) or high >= pos_ent + (sl_pips / 10000)
            in_pos := false
            strategy.close("VP Short")

plot(avg_vol, title="Avg Volume", color=color.blue, linewidth=2)
vol_color = volume > avg_vol * volume_threshold ? color.green : color.gray
plot(volume, title="Volume", color=vol_color, style=plot.style_columns)

if entry_long or entry_short
    plotshape(series=entry_long, style=shape.diamond, location=location.belowbar, color=color.green)
    plotshape(series=entry_short, style=shape.diamond, location=location.abovebar, color=color.red)

if entry_long
    alert(str.format("🟢 VOLUME PROFILE LONG | Vol: {0,number,0} | Avg: {1,number,0}", volume, avg_vol), freq=alert.freq_once_per_bar_close)
if entry_short
    alert(str.format("🔴 VOLUME PROFILE SHORT | Vol: {0,number,0} | Avg: {1,number,0}", volume, avg_vol), freq=alert.freq_once_per_bar_close)
