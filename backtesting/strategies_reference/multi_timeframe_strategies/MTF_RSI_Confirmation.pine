//@version=5
strategy("Multi-Timeframe RSI Confirmation", shorttitle="MTF-RSI", overlay=false, pyramiding=0, default_qty_type=strategy.percent_of_equity, default_qty_value=100, initial_capital=1000, commission_type=strategy.commission.percent, commission_value=0.1)

// ============================================================================
// SECTION 1: INPUT SETTINGS
// ============================================================================

rsi_period = input.int(14, title="RSI Period", minval=5, maxval=50)
overbought = input.int(70, title="Overbought Level", minval=50, maxval=90)
oversold = input.int(30, title="Oversold Level", minval=10, maxval=50)
mtf_timeframe = input.timeframe("60", title="Confirmation Timeframe")
tp_pips = input.float(120, title="Take Profit (pips)", minval=20, maxval=300)
sl_pips = input.float(70, title="Stop Loss (pips)", minval=20, maxval=150)

show_current_rsi = input.bool(true, title="Show Current RSI")
show_mtf_rsi = input.bool(true, title="Show MTF RSI")

// ============================================================================
// SECTION 2: RSI CALCULATIONS
// ============================================================================

current_rsi = ta.rsi(close, rsi_period)
mtf_rsi = request.security(syminfo.tickerid, mtf_timeframe, ta.rsi(close, rsi_period))

// ============================================================================
// SECTION 3: SIGNAL DETECTION
// ============================================================================

current_oversold = current_rsi < oversold
current_overbought = current_rsi > overbought
mtf_oversold = mtf_rsi < oversold
mtf_overbought = mtf_rsi > overbought

entry_long = current_oversold and mtf_oversold and current_rsi > current_rsi[1]
entry_short = current_overbought and mtf_overbought and current_rsi < current_rsi[1]

// ============================================================================
// SECTION 4: POSITION MANAGEMENT
// ============================================================================

var bool in_position = false
var string pos_dir = ""
var float pos_ent = 0.0

if entry_long and not in_position
    in_position := true
    pos_dir := "LONG"
    pos_ent := close
    strategy.entry("MTF RSI Long", strategy.long)

if entry_short and not in_position
    in_position := true
    pos_dir := "SHORT"
    pos_ent := close
    strategy.entry("MTF RSI Short", strategy.short)

// ============================================================================
// SECTION 5: EXIT LOGIC
// ============================================================================

if in_position
    if pos_dir == "LONG"
        tp = pos_ent + (tp_pips / 10000)
        sl = pos_ent - (sl_pips / 10000)
        if high >= tp or low <= sl or (current_rsi > overbought)
            in_position := false
            strategy.close("MTF RSI Long")
    else
        tp = pos_ent - (tp_pips / 10000)
        sl = pos_ent + (sl_pips / 10000)
        if low <= tp or high >= sl or (current_rsi < oversold)
            in_position := false
            strategy.close("MTF RSI Short")

// ============================================================================
// SECTION 6: VISUALIZATION
// ============================================================================

if show_current_rsi
    plot(current_rsi, title="Current RSI", color=color.blue, linewidth=2)

if show_mtf_rsi
    plot(mtf_rsi, title="MTF RSI", color=color.green, linewidth=2)

hline(overbought, title="Overbought", color=color.red, linestyle=hline.style_dashed)
hline(oversold, title="Oversold", color=color.green, linestyle=hline.style_dashed)
hline(50, title="Middle", color=color.gray, linestyle=hline.style_dotted)

// ============================================================================
// SECTION 7: ALERTS
// ============================================================================

if entry_long
    alert(str.format("🟢 MTF RSI LONG | Current: {0,number,0.0} | MTF: {1,number,0.0}", current_rsi, mtf_rsi), freq=alert.freq_once_per_bar_close)

if entry_short
    alert(str.format("🔴 MTF RSI SHORT | Current: {0,number,0.0} | MTF: {1,number,0.0}", current_rsi, mtf_rsi), freq=alert.freq_once_per_bar_close)
