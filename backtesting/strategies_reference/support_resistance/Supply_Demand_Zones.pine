//@version=5
strategy("Supply & Demand Zones", shorttitle="S&D", overlay=true, pyramiding=0, default_qty_type=strategy.percent_of_equity, default_qty_value=100, initial_capital=1000, commission_type=strategy.commission.percent, commission_value=0.1)

lookback = input.int(20, title="Lookback Period", minval=5, maxval=50)
zone_width_percent = input.float(2.0, title="Zone Width (%)", minval=0.5, maxval=5.0)
tp_pips = input.float(120, title="Take Profit (pips)", minval=20, maxval=300)
sl_pips = input.float(65, title="Stop Loss (pips)", minval=20, maxval=150)

recent_high = ta.highest(high, lookback)
recent_low = ta.lowest(low, lookback)

supply_zone_top = recent_high
supply_zone_bot = recent_high * (1 - (zone_width_percent / 100))
demand_zone_bot = recent_low
demand_zone_top = recent_low * (1 + (zone_width_percent / 100))

price_enters_demand = close >= demand_zone_bot and close <= demand_zone_top
price_enters_supply = close >= supply_zone_bot and close <= supply_zone_top
bounce_from_demand = low < demand_zone_bot and close > demand_zone_top
bounce_from_supply = high > supply_zone_top and close < supply_zone_bot

entry_long = (price_enters_demand or bounce_from_demand) and close > open
entry_short = (price_enters_supply or bounce_from_supply) and close < open

var bool in_pos = false
var string pos_type = ""
var float pos_ent = 0.0

if entry_long and not in_pos
    in_pos := true
    pos_type := "LONG"
    pos_ent := close
    strategy.entry("S&D Long", strategy.long)

if entry_short and not in_pos
    in_pos := true
    pos_type := "SHORT"
    pos_ent := close
    strategy.entry("S&D Short", strategy.short)

if in_pos
    if pos_type == "LONG"
        if high >= pos_ent + (tp_pips / 10000) or low <= pos_ent - (sl_pips / 10000)
            in_pos := false
            strategy.close("S&D Long")
    else
        if low <= pos_ent - (tp_pips / 10000) or high >= pos_ent + (sl_pips / 10000)
            in_pos := false
            strategy.close("S&D Short")

supply_color = color.new(color.red, 80)
demand_color = color.new(color.green, 80)

box.new(bar_index - lookback, supply_zone_top, bar_index, supply_zone_bot, bgcolor=supply_color, border_color=color.red, border_width=2)
box.new(bar_index - lookback, demand_zone_top, bar_index, demand_zone_bot, bgcolor=demand_color, border_color=color.green, border_width=2)

if entry_long or entry_short
    plotshape(series=entry_long, style=shape.diamond, location=location.belowbar, color=color.green)
    plotshape(series=entry_short, style=shape.diamond, location=location.abovebar, color=color.red)

if entry_long
    alert(str.format("🟢 SUPPLY & DEMAND LONG | Price: {0,number,0.00000} | Demand: {1,number,0.00000}", close, demand_zone_top), freq=alert.freq_once_per_bar_close)
if entry_short
    alert(str.format("🔴 SUPPLY & DEMAND SHORT | Price: {0,number,0.00000} | Supply: {1,number,0.00000}", close, supply_zone_top), freq=alert.freq_once_per_bar_close)
